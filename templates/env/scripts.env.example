# Scripts / deploy automation — categories only (no project-specific values).
# Copy to scripts/.env in target repo and fill.

# --- Deploy keys refs (paths or vault refs, not inline secrets) ---
# DEPLOYER_KEY_FILE=
# MNEMONIC_REF=

# --- Chain ---
# RPC_URL=
# CHAIN_ID=

# --- Target paths (artifacts, ABI sync) ---
# ARTIFACTS_DIR=
# ABI_SYNC_TARGET=

# --- Node / service base URLs (smoke, orchestration) ---
# NODE_URL=
# UPLOADER_URL=

# --- Shell glue ---
# SOURCE=
# TARGET=

# --- Deployment spec mode (optional hints for runners) ---
# DEPLOY_SCENARIO=
# DEPLOY_SPEC_PATH=
