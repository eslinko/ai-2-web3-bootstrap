# =============================================================================
# Security / crypto groups — classes of variables only (no secret values)
# =============================================================================

# --- HMAC (required when security.api_auth_mode includes hmac) [required/optional: conditional] ---
AMANITA_API_HMAC_SECRET_KEY=
AMANITA_API_HMAC_TIMESTAMP_WINDOW=300
AMANITA_API_HMAC_NONCE_CACHE_TTL=600

# --- Bearer: GPT Actions (required when security.gpt_actions_protection=bearer) [conditional] ---
GPT_ACTIONS_BEARER_SECRET=
# GPT actions integration toggle/reference (used when gpt.actions_integration=enabled) [optional]
GPT_ACTIONS_ENABLED=

# --- Bearer/HMAC: Edge -> backend callbacks (required when security.edge_auth_mode != none) [conditional] ---
NODE_AUTH_TOKEN=
EDGE_TO_BACKEND_SECRET=
OWN_AUTH_TOKEN=

# --- JWT RS256 upload_token (required when security.upload_token_mode=jwt_rs256) [conditional] ---
# Node: подпись токена (private). Uploader: проверка (public) — см. templates/env/arweave.env.example.
UPLOAD_TOKEN_JWT_PRIVATE_KEY=
UPLOAD_TOKEN_JWT_PRIVATE_KEY_FILE=
UPLOAD_TOKEN_JWT_PUBLIC_KEY=
UPLOAD_TOKEN_JWT_PUBLIC_KEY_FILE=

# --- Arweave signing (required when security.arweave_signing_mode=mock_jwk) [conditional/mock-only] ---
ARWEAVE_PRIVATE_KEY=
ARWEAVE_PRIVATE_KEY_FILE=
WALLET_MOCK_ARWEAVE_PRIVATE_KEY=
WALLET_MOCK_ARWEAVE_PRIVATE_KEY_FILE=
WALLET_MOCK_ARWEAVE_SIGN_MODE=

# --- EVM signing (required when security.evm_signing_mode != external_wallet_later) [conditional] ---
SELLER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
WALLET_MOCK_PRIVATE_KEY=
WALLET_MOCK_RPC_URL=

# --- Wallet auth challenge/signature (required when security.wallet_auth_mode=challenge_signature) [conditional] ---
WALLET_AUTH_MODE=challenge_signature
WALLET_AUTH_SCOPE=signing_flow
WALLET_AUTH_DOMAIN=
WALLET_AUTH_CHALLENGE_TTL_SEC=120
WALLET_AUTH_SESSION_TTL_SEC=300

# --- Secrets source: Vault (required when security.secrets_source=vault|hybrid) [conditional] ---
SECRETS_PROVIDER=
VAULT_ADDR=
VAULT_TOKEN=
VAULT_PATH=

# --- GPT contract/rulebook refs (classes only; use when gpt.enabled=true) [optional] ---
GPT_RULEBOOK_SOURCE_REF=
GPT_OUTPUT_CONTRACT_VERSION=v1
GPT_INGEST_MODE=
