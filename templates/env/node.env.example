# =============================================================================
# Web2-нода (FastAPI + опц. Telegram) — эталон: bot/.env.example
# =============================================================================
# Группы: runtime API | blockchain | storage/uploads | GPT Actions | Supabase | secrets provider

# --- Runtime API ---
AMANITA_API_ENVIRONMENT=development
AMANITA_API_HOST=0.0.0.0
AMANITA_API_PORT=8000
PORT=8000
AMANITA_API_LOG_LEVEL=INFO
AMANITA_API_CORS_ORIGINS=*
AMANITA_API_TRUSTED_HOSTS=*

# --- Blockchain (обязательно для web3-операций ноды) ---
WEB3_PROVIDER_URI=http://127.0.0.1:8545
BLOCKCHAIN_PROFILE=localhost
MAGIC_REGISTRY_CONTRACT_ADDRESS=
ABI_BASE_DIR=artifacts/contracts
SELLER_PRIVATE_KEY=
SELLER_ADDRESS=

# --- Каталог / поведение старта (опционально) ---
LOAD_CATALOG=true
ENVIRONMENT=local
DEPLOYMENT_PROFILE=localhost

# --- Интеграции e-commerce / HMAC (опционально до появления интегратора) ---
AMANITA_API_HMAC_SECRET_KEY=
AMANITA_API_HMAC_TIMESTAMP_WINDOW=300

# --- Custom GPT Actions (Bearer на выбранных префиксах; пусто = dev без проверки) ---
GPT_ACTIONS_BEARER_SECRET=

# --- Uploader ↔ Node: общий Bearer (эталон: NODE_AUTH_TOKEN / EDGE_TO_BACKEND_SECRET / OWN_AUTH_TOKEN с приоритетом в коде) ---
NODE_AUTH_TOKEN=
EDGE_TO_BACKEND_SECRET=
OWN_AUTH_TOKEN=

# --- Arweave client (если нода ходит к сети Arweave напрямую) ---
ARWEAVE_SERVICE_URL=
ARWEAVE_AUTH_TOKEN=

# --- Telegram / WebApp (опционально) ---
TELEGRAM_BOT_TOKEN=
WALLET_APP_URL=

# --- Supabase (опционально) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Секреты: env vs Vault (production) ---
SECRETS_PROVIDER=
# VAULT_ADDR=
# VAULT_TOKEN=
# VAULT_PATH=
