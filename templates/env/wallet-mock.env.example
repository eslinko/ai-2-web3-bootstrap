# Mock signing client (wallet/mock-runner-style) — классы переменных
# v1.8: эталонный mock-runner копируется bundled; этот файл — контракт env вокруг него.
# Не коммитить реальные ключи. Скопировать в .env локально и добавить в .gitignore.

# --- Fixed mock identity (prototype single-user) ---
# USER_ID=                    # Один идентификатор пользователя на ноде (согласовать с draft/activity flow)
# IDENTITY_CONFIG_PATH=       # Опционально: путь к локальному json конфигу identity (вне git)

# --- Node API (очередь подписей, wallet-auth) ---
# NODE_BASE_URL=
# WALLET_AUTH_MODE=           # например challenge_signature | legacy — по контракту вашей ноды

# --- EVM signing (отдельный контур от Arweave) ---
# WALLET_MOCK_PRIVATE_KEY=    # hex dev key; в prod — вне репо
# WALLET_MOCK_RPC_URL=        # RPC для ethers; должен соответствовать сети ноды

# --- Arweave signing (отдельный контур) ---
# ARWEAVE_SIGN_MODE=          # например local-valid | poc-jwk | dummy — по эталону/ноде
# ARWEAVE_JWK_PATH=           # или inline JWK через отдельную переменную, если принято в проекте

# --- Uploader (crystalize) ---
# ARWEAVE_UPLOADER_BASE_URL=
# Путь к фикстуре/локальному uploader, если режим предполагает — только dev:
# ARWEAVE_UPLOADER_PATH=

# --- Опционально: оркестрация E2E ---
# FLOOU_DONE_MARKER_FILE=     # маркер для внешних скриптов; не часть prod API
