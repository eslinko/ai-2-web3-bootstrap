# =============================================================================
# arweave-uploader service (эталон: arweave-uploader/.env.example + dist/config.js)
# Классы переменных — без реальных секретов. Не коммитить заполненный .env.
# =============================================================================

# --- Server ---
PORT=3000

# --- Publish mode: real Arweave vs mock (см. decisions uploader.mode) ---
# USE_REAL_ARWEAVE=true — реальная сеть; нужен ARWEAVE_PRIVATE_KEY* (JWK релея на uploader).
# USE_REAL_ARWEAVE=false — mock bundle_tx_id без сети (интеграции / CI).
USE_REAL_ARWEAVE=false

# --- Relay ingress (optional caller trust; эталон RELAY_AUTH_TOKEN) ---
# Если не задан — в эталоне логируется «endpoint is open»; prod должен явно решить gate.
RELAY_AUTH_TOKEN=

# --- Backend sync (uploader → node; см. uploader.callback_mode) ---
# BACKEND_URL — база API ноды без хвоста /v1
BACKEND_URL=http://127.0.0.1:8000
# Один секрет на uploader и ноде для исходящих PUT/POST (эталон: NODE_AUTH_TOKEN)
NODE_AUTH_TOKEN=
# Синоним/линейка эталона для согласования с нодой (класс переменной)
UPLOADER_TO_BACKEND_SECRET=

# Mock backend calls (dev only; эталон BACKEND_USE_MOCK)
BACKEND_USE_MOCK=true
# BACKEND_MOCK_PUT_STATUS=200
# BACKEND_MOCK_CALLBACK=200
# BACKEND_MOCK_ALLOW_REQUEST_OVERRIDE=
# BACKEND_MOCK_TEST_SECRET=

# --- JWT verify: upload_token на uploader (RS256; публичный ключ) ---
# Должен соответствовать паре, которой нода подписывает токен (см. security.upload_token_mode=jwt_rs256).
UPLOAD_TOKEN_JWT_PUBLIC_KEY=
# UPLOAD_TOKEN_JWT_PUBLIC_KEY_FILE=

# --- Arweave network + relay signing key (публикация bundle) ---
ARWEAVE_PROTOCOL=https
ARWEAVE_HOST=arweave.net
ARWEAVE_PORT=443
# JWK релея (одна строка JSON или файл) — эталон ARWEAVE_PRIVATE_KEY | ARWEAVE_PRIVATE_KEY_FILE
ARWEAVE_PRIVATE_KEY=
# ARWEAVE_PRIVATE_KEY_FILE=./keys/arweave-relay-jwk.json

# --- Diagnostics / smoke (классы из эталона; опционально) ---
# UPLOAD_TOKEN_DEBUG_PEM=
# SMOKE_REAL=
# SMOKE_JWT_PRIVATE_KEY_FILE=
